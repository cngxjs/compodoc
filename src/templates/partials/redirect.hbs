<script>
// Automatic redirect when no README exists and overview is disabled
(function() {
    function findFirstAvailablePage() {
        // Wait for menu to be loaded
        var menuItems = document.querySelectorAll('.menu a[href]');
        if (menuItems.length === 0) {
            // Menu not loaded yet, try again in a moment
            setTimeout(findFirstAvailablePage, 100);
            return;
        }
        
        var redirectTarget = null;
        
        // Priority order for page types (excluding overview and readme-related pages)
        var priorityPages = [
            'components/', // Components section
            'modules.html', // Modules page
            'directives/', // Directives section  
            'injectables/', // Services/Injectables section
            'pipes/', // Pipes section
            'classes/', // Classes section
            'interfaces/', // Interfaces section
            'miscellaneous.html', // Miscellaneous page
            'coverage.html' // Coverage page
        ];
        
        // First, try to find priority pages
        for (var p = 0; p < priorityPages.length; p++) {
            for (var i = 0; i < menuItems.length; i++) {
                var href = menuItems[i].getAttribute('href');
                if (href && href.indexOf(priorityPages[p]) !== -1) {
                    // Skip if it's an overview or readme link
                    if (href.indexOf('overview') === -1 && href.indexOf('index.html') === -1) {
                        redirectTarget = href;
                        break;
                    }
                }
            }
            if (redirectTarget) break;
        }
        
        // If no priority page found, take the first non-overview, non-index page
        if (!redirectTarget) {
            for (var i = 0; i < menuItems.length; i++) {
                var href = menuItems[i].getAttribute('href');
                if (href && 
                    href.indexOf('overview') === -1 && 
                    href.indexOf('index.html') === -1 &&
                    href.indexOf('#') !== 0 && // Skip anchor links
                    href.indexOf('javascript:') !== 0 && // Skip JS links
                    href.length > 0) {
                    redirectTarget = href;
                    break;
                }
            }
        }
        
        // Final fallback
        if (!redirectTarget) {
            redirectTarget = 'coverage.html';
        }
        
        // Perform the redirect
        window.location.href = redirectTarget;
    }
    
    // Start looking for the redirect target
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', findFirstAvailablePage);
    } else {
        findFirstAvailablePage();
    }
})();
</script>

<div class="content-data">
    <div class="alert alert-info">
        <h4><i class="fa fa-info-circle"></i> Redirecting...</h4>
        <p>No README found and overview is disabled. Redirecting to the first available documentation page...</p>
        <p>If you are not redirected automatically, <a href="#" onclick="window.location.href=document.querySelector('.menu a[href]:not([href*=overview]):not([href*=index])').href || 'coverage.html'">click here</a>.</p>
    </div>
</div>
