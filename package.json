{
    "name": "@cngx/compodocx",
    "version": "0.0.1",
    "description": "Modern documentation tool for Angular applications",
    "main": "dist/index.js",
    "bin": {
        "compodocx": "./bin/index-cli.js",
        "compodoc": "./bin/index-cli.js"
    },
    "scripts": {
        "start": "npm run test:watch",
        "copy-libs": "node tools/copy-libs.js",
        "*********BUILD********": "*******************",
        "prebuild": "rimraf dist/*",
        "build": "rollup -c rollup/rollup.config.mjs --bundleConfigAsCjs && npm run build-schematics",
        "build-schematics": "tsc --project schematics/tsconfig.json && cp schematics/collection.json dist",
        "*********UTILS********": "*******************",
        "changelog": "auto-changelog -o CH.md  --template tools/changelog-template.hbs -u",
        "angularexpo": "npm run pretest && node tools/tests-angularexpo.js",
        "download-api-list": "node tools/download-api-list.js",
        "codecov": "codecov -f coverage/lcov_merged.info",
        "backup-package-json": "node tools/backup-package-json.js",
        "restore-package-json": "node tools/restore-package-json.js",
        "madge": "./node_modules/.bin/madge --warning -i dist/madge.png src/index-cli.ts",
        "*********TEMPLATE PLAYGROUND********": "*******************",
        "build-template-playground": "node tools/build-template-playground.js",
        "start-playground": "npm run build && npm run build-template-playground && node -e \"const { TemplatePlaygroundServer } = require('./dist/template-playground-server.js'); const server = new TemplatePlaygroundServer(); server.start().then(() => console.log('✅ Template Playground started at http://localhost:3001')).catch(e => console.error('❌ Error:', e.message));\"",
        "playground": "npm run start-playground",
        "dev:playground": "node scripts/start-playground.js",
        "playground:simple": "node scripts/start-playground-simple.js",
        "*********TEST********": "*******************",
        "pretest": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "*********TEST E2E********": "*******************",
        "test:simple-doc": "ts-node ./bin/index-cli.js -p ./test/fixtures/sample-files/tsconfig.simple.json -d doc -s --port 4000",
        "test-e2e-playwright": "npx playwright test",
        "*********PUBLISH********": "*******************",
        "prepublishOnly": "npm run build && npm run backup-package-json && npm run copy-libs",
        "postpublish": "npm run restore-package-json",
        "*********QUALITY********": "*******************",
        "lint": "eslint src/**/*.ts",
        "format:check": "prettier --config ./.prettierrc --list-different \"src/**/*.ts\"",
        "format:write": "prettier --config ./.prettierrc --write \"src/**/*.ts\""
    },
    "watch": {
        "build": {
            "patterns": [
                "src/**/*.ts"
            ],
            "extensions": "js,ts",
            "quiet": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cngxjs/compodocx.git"
    },
    "keywords": [
        "angular",
        "documentation",
        "components",
        "standalone",
        "signals",
        "api-docs",
        "compodoc"
    ],
    "author": "Christian Weiss",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/cngxjs/compodocx/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "homepage": "https://github.com/cngxjs/compodocx#readme",
    "dependencies": {
        "@angular-devkit/schematics": "21.1.0",
        "@babel/core": "7.28.6",
        "@babel/plugin-transform-private-methods": "7.28.6",
        "@babel/preset-env": "7.28.6",
        "@compodoc/live-server": "^1.2.3",
        "@compodoc/ngd-transformer": "^2.1.3",
        "@polka/send-type": "^0.5.2",
        "body-parser": "^2.2.2",
        "bootstrap.native": "^5.1.6",
        "cheerio": "1.1.2",
        "chokidar": "^5.0.0",
        "colors": "1.4.0",
        "commander": "^14.0.2",
        "cosmiconfig": "^9.0.0",
        "decache": "^4.6.2",
        "es6-shim": "^0.35.8",
        "fancy-log": "^2.0.0",
        "fast-glob": "^3.3.3",
        "fs-extra": "^11.3.3",
        "glob": "^13.0.0",
        "handlebars": "^4.7.8",
        "html-entities": "^2.6.0",
        "i18next": "25.7.4",
        "json5": "^2.2.3",
        "loglevel": "^1.9.2",
        "loglevel-plugin-prefix": "^0.8.4",
        "lunr": "^2.3.9",
        "marked": "7.0.3",
        "minimist": "^1.2.8",
        "neotraverse": "^0.6.18",
        "os-name": "4.0.1",
        "picocolors": "^1.1.1",
        "polka": "^0.5.2",
        "prismjs": "^1.30.0",
        "semver": "^7.7.3",
        "sirv": "^3.0.2",
        "svg-pan-zoom": "^3.6.2",
        "tablesort": "^5.7.0",
        "ts-morph": "^27.0.2",
        "uuid": "11.1.0",
        "vis-network": "^10.0.2"
    },
    "devDependencies": {
        "@istanbuljs/nyc-config-typescript": "1.0.2",
        "@playwright/test": "1.57.0",
        "@rollup/plugin-typescript": "12.3.0",
        "@types/archiver": "^7.0.0",
        "@types/chai": "5.2.3",
        "@types/fs-extra": "11.0.4",
        "@types/marked": "6.0.0",
        "@types/mocha": "10.0.10",
        "@types/node": "25.0.9",
        "@types/polka": "^0.5.8",
        "@types/semver": "7.7.1",
        "@types/traverse": "0.6.37",
        "@typescript-eslint/eslint-plugin": "7.18.0",
        "@typescript-eslint/parser": "7.18.0",
        "archiver": "^7.0.1",
        "auto-changelog": "2.5.0",
        "chai": "4.4.1",
        "codecov": "3.8.3",
        "cpx2": "^8.0.0",
        "cross-env": "10.1.0",
        "eslint": "8.56.0",
        "husky": "9.1.7",
        "madge": "8.0.0",
        "mocha": "11.7.5",
        "nodemon": "3.1.11",
        "npm-watch": "0.13.0",
        "nyc": "17.1.0",
        "prettier": "3.8.0",
        "pretty-quick": "4.2.2",
        "rimraf": "6.1.2",
        "rollup": "4.55.1",
        "rollup-plugin-typescript2": "0.36.0",
        "sinon": "21.0.1",
        "sonar-scanner": "3.1.0",
        "source-map-support": "0.5.21",
        "supertest": "7.2.2",
        "ts-node": "10.9.2",
        "tslib": "2.8.1",
        "vitest": "^4.1.2"
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged --pattern \"**/*.ts\""
        }
    },
    "schematics": "./dist/collection.json",
    "ng-add": {
        "save": "devDependencies"
    }
}
