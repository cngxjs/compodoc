{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "dom"
        ],
        "module": "ES2022",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "importHelpers": true,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*"
    ]
}
